rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone to read products and announcements, but only authenticated admins to write
    match /products/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /announcements/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow anyone (unauthenticated customers) to create an order
    // But only allow authenticated admins to read, update, or delete them
    match /orders/{document=**} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Default fallback
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
